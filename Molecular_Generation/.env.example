# Copy to .env and adjust values locally. .env is git-ignored.

# Override generator checkpoint directory (defaults to checkpoints/generator).
GENERATOR_CHECKPOINT=checkpoints/generator

# Backend bind address / port.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# CORS: comma-separated origins allowed by FastAPI (defaults handle localhost).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Logging: loguru level. DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
